{
	"name": "meta-app",
	"version": "1.0.0",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"test": "jest",
		"typecheck": "tsc --noEmit",
		"biome:check": "biome check --write src/"
	},
	"dependencies": {
		"@babel/runtime": "^7.29.7",
		"@expo/vector-icons": "^14.1.0",
		"@hookform/resolvers": "^5.0.0",
		"@react-native-async-storage/async-storage": "2.1.2",
		"@react-navigation/drawer": "^7.13.4",
		"@react-navigation/native": "^7.3.13",
		"babel-preset-expo": "^13.2.5",
		"expo": "~53.0.0",
		"expo-constants": "~17.1.8",
		"expo-font": "~13.3.2",
		"expo-linking": "~7.1.7",
		"expo-router": "~5.1.11",
		"expo-status-bar": "~2.2.3",
		"react": "19.0.0",
		"react-dom": "19.0.0",
		"react-hook-form": "^7.55.0",
		"react-native": "0.79.6",
		"react-native-gesture-handler": "~2.24.0",
		"react-native-reanimated": "~3.17.0",
		"react-native-safe-area-context": "5.4.0",
		"react-native-screens": "~4.11.1",
		"react-native-toast-message": "^2.4.0",
		"react-native-web": "~0.20.0",
		"zod": "^3.23.0",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@babel/core": "^7.25.0",
		"@biomejs/biome": "^2.5.5",
		"@testing-library/react-native": "^12.9.0",
		"@types/jest": "^30.0.0",
		"@types/node": "~22.0.3",
		"@types/react": "~19.0.14",
		"babel-plugin-module-resolver": "^5.0.0",
		"jest": "^29.7.0",
		"jest-expo": "~53.0.0",
		"react-test-renderer": "19.0.0",
		"typescript": "~5.8.3"
	},
	"jest": {
		"preset": "jest-expo",
		"setupFiles": [
			"./jest.setup.js"
		],
		"transformIgnorePatterns": [
			"node_modules/(?!(?:.pnpm|expo(?:-[^/]*)?|@expo|react-native|@react-native|react-native-[^/]*|@react-native-[^/]*|react-native-web|react-native-gesture-handler|react-native-reanimated|@react-native-async-storage/async-storage|@react-native-async-storage|@react-navigation|zustand|zod)/)"
		],
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/src/$1",
			"^react-native/src/private/specs/modules/NativeSourceCode$": "react-native/src/private/specs_DEPRECATED/modules/NativeSourceCode"
		}
	}
}
