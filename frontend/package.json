{
	"name": "meta-app",
	"version": "1.0.0",
	"private": true,
	"main": "expo-router/entry",
	"scripts": {
		"start": "expo start",
		"android": "expo start --android",
		"ios": "expo start --ios",
		"web": "expo start --web",
		"test": "jest",
		"typecheck": "tsc --noEmit",
		"biome:check": "biome check --write src/"
	},
	"dependencies": {
		"@babel/runtime": "^7.29.7",
		"@expo/vector-icons": "^14.0.4",
		"@react-native-async-storage/async-storage": "1.23.1",
		"expo": "~52.0.0",
		"expo-router": "~4.0.0",
		"expo-status-bar": "~2.0.0",
		"react": "18.3.1",
		"react-dom": "18.3.1",
		"react-native": "0.76.9",
		"react-native-safe-area-context": "4.12.0",
		"react-native-screens": "~4.4.0",
		"react-native-web": "~0.19.13",
		"zod": "^3.23.0",
		"zustand": "^5.0.0"
	},
	"devDependencies": {
		"@babel/core": "^7.25.0",
		"@biomejs/biome": "^2.5.5",
		"@testing-library/react-native": "^12.9.0",
		"@types/jest": "^30.0.0",
		"@types/node": "~22.0.3",
		"@types/react": "~18.3.0",
		"babel-plugin-module-resolver": "^5.0.0",
		"jest": "^29.7.0",
		"jest-expo": "~52.0.0",
		"react-test-renderer": "18.3.1",
		"typescript": "~5.3.0"
	},
	"jest": {
		"preset": "jest-expo",
		"setupFiles": [
			"./jest.setup.js"
		],
		"transformIgnorePatterns": [
			"node_modules/(?!(?:.pnpm|expo(?:-[^/]*)?|@expo|react-native|@react-native|react-native-[^/]*|@react-native-[^/]*|react-native-web|@react-native-async-storage/async-storage|@react-native-async-storage|@react-navigation|zustand|zod)/)"
		],
		"moduleNameMapper": {
			"^@/(.*)$": "<rootDir>/src/$1"
		}
	}
}
